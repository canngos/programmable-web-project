PORT=5051
AUX_DB_PATH=./data/notifications.db

# Background sweep: cancel unpaid bookings whose flight departure is in the past.
# Naive departure_time from the API is read in TZ (e.g. Europe/Helsinki); match docker-compose / main API.
BOOKING_SWEEP_ENABLED=true
BOOKING_SWEEP_INTERVAL_SECONDS=600
MAIN_API_BASE_URL=http://localhost:8080
# Admin API key used for /api/users/ access during sweep:
MAIN_API_ADMIN_API_KEY=