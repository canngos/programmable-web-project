    {
      "name": "Users / Tokens",
      "item": [
        {
          "name": "Issue Token by User ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('userId', json.user.id);",
                  "}",
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token is present', () => pm.expect(json.token).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{userId}}",
                "token"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Current User Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const refreshed = pm.response.headers.get('X-Refreshed-Token');",
                  "if (refreshed) pm.collectionVariables.set('token', refreshed);",
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
